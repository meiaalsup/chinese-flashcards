{
  "name": "cc-cedict",
  "version": "1.1.1",
  "description": "Full-featured Chinese-English dictionary library using CC-CEDICT data. Powerful lookup for Mandarin, Simplified, Traditional characters & Pinyin, plus word variants, classifiers, and more.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "edvardsr",
  "license": "MIT",
  "dependencies": {
    "unzipper": "^0.12.3"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edvardsr/cc-cedict"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:watch": "tsc --watch",
    "prebuild": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/build.js",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json --noEmit",
    "test": "npm run typecheck && vitest run",
    "test:only": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "cc-cedict",
    "cedict",
    "chinese",
    "mandarin",
    "dictionary",
    "chinese dictionary",
    "mandarin dictionary",
    "chinese-english",
    "chinese-english dictionary",
    "chinese english",
    "english chinese",
    "english-chinese",
    "simplified chinese",
    "traditional chinese",
    "simplified",
    "traditional",
    "hanzi",
    "pinyin",
    "translation",
    "lookup",
    "cedict parser",
    "word",
    "words",
    "typescript",
    "api",
    "zhongwen",
    "汉字",
    "汉英",
    "english",
    "language",
    "lexicon"
  ],
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/unzipper": "^0.10.11",
    "@vitest/coverage-v8": "^4.0.9",
    "@vitest/ui": "^4.0.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9"
  }
}
